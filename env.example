# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit your real keys.

SECRET_KEY=replace-with-a-long-random-string

# Get a free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Get a free key at https://jooble.org/api/about (optional — app works with just Adzuna)
JOOBLE_API_KEY=
